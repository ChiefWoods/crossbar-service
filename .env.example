# =============================================================================
# Core Server Configuration
# =============================================================================

# HTTP server port
PORT=8080

# WebSocket server port
WS_PORT=8081

# Set to "true" to disable HTTP API
DISABLE_API=false

# =============================================================================
# Blockchain RPC Configuration
# =============================================================================

# Solana mainnet RPC endpoint (recommended for better performance)
SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Solana devnet RPC endpoint (recommended for better performance)
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# =============================================================================
# IPFS Configuration
# =============================================================================

# IPFS gateway for fetching data
IPFS_GATEWAY_URL=https://ipfs.io

# Pinata JWT key for storage (optional)
# PINATA_JWT_KEY=

# Pinata gateway key (optional)
# PINATA_GATEWAY_KEY=

# Local Kubo IPFS node URL (optional)
# KUBO_URL=

# =============================================================================
# Database Configuration (Optional)
# =============================================================================

# PostgreSQL connection string (optional)
# DATABASE_URL=

# PostgreSQL username (optional)
# PGUSER=

# PostgreSQL password (optional)
# PGPASSWORD=

# PostgreSQL database name (optional)
# PGDATABASE=

# PostgreSQL host (optional)
# PGHOST=

# PostgreSQL port (optional)
# PGPORT=

# =============================================================================
# Performance & Caching
# =============================================================================

# Number of Tokio worker threads
BROADCAST_WORKER_THREADS=32

# Cache TTL for simulations (in seconds)
SIMULATION_CACHE_TTL_SECONDS=3

# Disable caching entirely
DISABLE_CACHE=false

# Rate limiting configuration (optional)
# RATE_LIMIT=

# =============================================================================
# Development & Debugging
# =============================================================================

# Log level (error, warn, info, debug, trace)
RUST_LOG=info

# Enable tokio console debugging
TOKIO_CONSOLE=false

# Port for tokio console
TOKIO_CONSOLE_PORT=6669

# Development mode flag
IS_LOCALHOST=false
